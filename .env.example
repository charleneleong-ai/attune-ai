# Copy to .env for local training runs. Do not commit real secrets.

# W&B reads WANDB_API_KEY from the environment when online logging is enabled.
WANDB_API_KEY=""
WANDB_PROJECT=attune-ai
WANDB_ENTITY=chaleong

HF_TOKEN=""
OPENAI_API_KEY=""

# Use offline for local dry runs, online when a real W&B login/key is configured.
WANDB_MODE=online
